{
  "name": "@couponhub/backend",
  "version": "0.0.0",
  "description": "CouponHub backend API",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "tsx src/server.ts",
